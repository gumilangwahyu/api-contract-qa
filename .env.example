# Database (PostgreSQL / SQLite)
DATABASE_URL="postgresql://username:password@hostname:port/dbname?pgbouncer=true"

# NextAuth / GitHub OAuth
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key

# Default Admin / Demo Account
DEMO_USER_EMAIL=demo@local
ADMIN_USERS=admin@yourdomain.com

# GitHub Sync Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repository_name
GITHUB_BACKUP_BRANCH=main

# Vercel Blob / Key-Value Storage
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token
KV_REST_API_TOKEN=your_vercel_kv_token

# Cron Secret Security
CRON_SECRET=your_cron_job_auth_secret

# Application Limits & Configurations
MAX_UPLOAD_SIZE=102400  # 100KB
MAX_PROJECTS=5
MAX_ENDPOINTS_PER_PROJECT=50
MAX_TEST_CASES_PER_PROJECT=100
MOCK_RATE_LIMIT_PER_MINUTE=600

# Background Job Engine Configuration
JOB_BACKOFF_BASE_MS=2000
JOB_MAX_ATTEMPTS=3
PROCESS_ENDPOINT=http://localhost:3000/api/jobs/process

# Gemini AI Integration Key
GEMINI_API_KEY=your_gemini_api_key